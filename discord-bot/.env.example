DISCORD_TOKEN=your-discord-bot-token

# 投稿先チャンネル（複数サーバー対応）
# 形式: サーバー名:チャンネルID,サーバー名:チャンネルID
DISCORD_CHANNELS=メインサーバー:123456789012345678,テストサーバー:987654321098765432

# 監視するRSSフィードURL（カンマ区切り）
FEED_URLS=https://musoukun.github.io/recomend-feeder/feed-ai.xml,https://musoukun.github.io/recomend-feeder/feed-politics.xml,https://musoukun.github.io/recomend-feeder/feed-news.xml,https://musoukun.github.io/recomend-feeder/feed-other.xml

# チェック間隔（分）
POLL_INTERVAL_MINUTES=10
